# Environment variable template for SkillBridge Frontend
# Copy this file to .env and fill in your actual values
# NEVER commit your actual .env file to version control

# ── API Base URL ──────────────────────────────────────────
# In development, leave this empty — Vite proxies /api requests
# to localhost:5000 automatically (see vite.config.js)
#
# In production, this is not needed as the frontend is served
# by the Express backend itself.
#
# Only set this if you are running the frontend separately
# from a custom deployment (e.g. Vercel / Netlify frontend-only)
# VITE_API_BASE_URL=https://your-backend.onrender.com

# ── Razorpay Public Key ───────────────────────────────────
# The PUBLIC key (rzp_test_* or rzp_live_*) exposed to the browser
# This is safe to expose — the secret key must stay server-side only
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
