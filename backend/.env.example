# Environment variable template for SkillBridge Backend
# Copy this file to .env and fill in your actual values
# NEVER commit your actual .env file to version control

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/skillbridge

# ── Authentication ────────────────────────────────────────
# A long, random secret string for signing JWTs
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-replace-this

# How long tokens remain valid (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# ── Payment Gateway (Razorpay) ────────────────────────────
# Get your keys at: https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) during development
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
