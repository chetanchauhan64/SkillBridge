# Root — all OS & editor artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Dependencies — never commit node_modules
node_modules/
**/node_modules/

# Environment files — keep secrets out of git
.env
.env.local
.env.production
**/.env
**/.env.local
**/.env.production

# Build artifacts
dist/
build/
.vite/

# Logs
*.log
npm-debug.log*

# Prisma generated client (auto-regenerated, no need to commit)
**/generated/prisma/
